<Window x:Class="ElBruno.CopilotCLIMonitor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="520" Height="420"
        MinWidth="480" MinHeight="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Preferences" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="Customize notifications and runtime behavior."
                       Foreground="Gray" FontSize="11" Margin="0,2,0,12"/>

            <CheckBox x:Name="NotificationsEnabledCheckBox"
                      Content="Enable notifications" Margin="0,0,0,8"/>
            <CheckBox x:Name="SoundEnabledCheckBox"
                      Content="Play sound for notifications" Margin="0,0,0,8"/>
            <CheckBox x:Name="StartWithWindowsCheckBox"
                      Content="Start with Windows" Margin="0,0,0,12"/>
            <CheckBox x:Name="TelemetryOptInCheckBox"
                      Content="Share anonymous telemetry (opt-in)" Margin="0,0,0,12"/>

            <TextBlock Text="Quiet Hours" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <CheckBox x:Name="QuietHoursEnabledCheckBox"
                      Content="Enable quiet hours" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="Start hour:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="QuietHoursStartComboBox" Width="70"/>
                <TextBlock Text="End hour:" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <ComboBox x:Name="QuietHoursEndComboBox" Width="70"/>
            </StackPanel>

            <TextBlock Text="Logging Level" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <ComboBox x:Name="LogLevelComboBox" Width="180"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="80" IsDefault="True" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
