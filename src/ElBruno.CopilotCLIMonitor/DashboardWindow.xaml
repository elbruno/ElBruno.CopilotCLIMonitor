<Window x:Class="ElBruno.CopilotCLIMonitor.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CopilotCLI Monitor — Dashboard"
        Width="680" Height="480"
        MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="CopilotCLI Monitor" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="Recent notification events from GitHub Copilot CLI hooks"
                       Foreground="Gray" FontSize="11" Margin="0,2,0,0"/>
            <Separator Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Event list -->
        <ListView x:Name="EventList" Grid.Row="1"
                  BorderThickness="1" BorderBrush="#CCCCCC"
                  SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Time" Width="140"
                                    DisplayMemberBinding="{Binding TimestampDisplay}"/>
                    <GridViewColumn Header="Event" Width="160"
                                    DisplayMemberBinding="{Binding EventTypeDisplay}"/>
                    <GridViewColumn Header="Repository" Width="130"
                                    DisplayMemberBinding="{Binding Repository}"/>
                    <GridViewColumn Header="Message" Width="220"
                                    DisplayMemberBinding="{Binding Message}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Foreground="Gray" FontSize="11" Margin="0,0,12,0"/>
            <Button Content="Clear History" Width="110" Height="28"
                    Click="ClearHistory_Click"/>
            <Button Content="Close" Width="80" Height="28"
                    Margin="8,0,0,0" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
