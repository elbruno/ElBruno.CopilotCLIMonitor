<Application x:Class="ElBruno.CopilotCLIMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Buttons.xaml"/>
                <ResourceDictionary Source="/Styles/TextBlocks.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Default Window Style -->
            <Style TargetType="Window">
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Background" Value="{StaticResource GitHubBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource GitHubTextBrush}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
