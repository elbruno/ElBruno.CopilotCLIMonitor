<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Heading 1 Style (Large, Bold) -->
    <Style x:Key="Heading1TextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource GitHubTextBrush}"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <!-- Heading 2 Style (Medium, Bold) -->
    <Style x:Key="Heading2TextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource GitHubTextBrush}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Heading 3 Style (Small, Bold) -->
    <Style x:Key="Heading3TextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource GitHubTextBrush}"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <!-- Body Text Style (Regular) -->
    <Style x:Key="BodyTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource GitHubTextBrush}"/>
        <Setter Property="LineHeight" Value="18"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Secondary Text Style (Muted) -->
    <Style x:Key="SecondaryTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource GitHubSecondaryTextBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Caption Style (Small, Muted) -->
    <Style x:Key="CaptionTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource GitHubSecondaryTextBrush}"/>
    </Style>

    <!-- Monospace Code Style -->
    <Style x:Key="CodeTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas, Courier New, monospace"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource GitHubAccentBrush}"/>
        <Setter Property="Background" Value="{StaticResource GitHubSurfaceBrush}"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

</ResourceDictionary>
